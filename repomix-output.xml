// Style de carte épuré et moderne (Style "Silver/Light" pour éviter le côté vieillot)
const MODERN_MAP_STYLE = [
  { "elementType": "geometry", "stylers": [{ "color": "#f5f5f5" }] },
  { "elementType": "labels.icon", "stylers": [{ "visibility": "off" }] },
