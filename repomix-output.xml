// components/primitives/Button.tsx
// Professional, accessible, fully-featured button component
// Supports: 4 variants × 3 sizes × multiple states + icons + loading

import React, { useMemo } from 'react';
import {
  StyleSheet,
  Text,
  ActivityIndicator,
  ViewStyle,
  TextStyle,
  Pressable,
  GestureResponderEvent,
} from 'react-native';
import { MaterialIcons } from '@expo/vector-icons';
import { colors, spacing, typography, radii, shadows } from '@/design';
import * as Haptics from 'expo-haptics';

/**
 * Button variants - Visual hierarchy
 */
type ButtonVariant = 'primary' | 'secondary' | 'outline' | 'ghost';

/**
 * Button sizes - Touch target compliance
 */
type ButtonSize = 'sm' | 'md' | 'lg';

/**
 * Button state for loading/disabled
 */
type ButtonState = 'default' | 'loading' | 'disabled' | 'error';

/**
 * Complete button props
 */
export interface ButtonProps {
  /** Button label text - required */
  label: string;

  /** Callback when button is pressed */
  onPress: (e?: GestureResponderEvent) => void | Promise<void>;

  /** Visual variant */
  variant?: ButtonVariant;

  /** Button size */
  size?: ButtonSize;

  /** Disabled state */
  disabled?: boolean;

  /** Loading state - shows spinner */
  loading?: boolean;

  /** Icon from MaterialIcons */
  icon?: keyof typeof MaterialIcons.glyphMap;

  /** Icon position */
  iconPosition?: 'left' | 'right';

  /** Full width button */
  fullWidth?: boolean;

  /** Custom test ID */
  testID?: string;

  /** Accessibility label */
  accessibilityLabel?: string;

  /** Accessibility hint */
  accessibilityHint?: string;

  /** Custom styles override */
  style?: ViewStyle;

  /** Custom text style override */
  textStyle?: TextStyle;

  /** Enable haptic feedback */
  haptic?: boolean;
}

/**
 * Professional Button Component
 *
 * @example
 * // Primary button
 * <Button label="Save" variant="primary" onPress={handleSave} />
 *
 * @example
 * // With loading state
 * <Button label="Submit" loading={isLoading} onPress={handleSubmit} />
 *
 * @example
 * // With icon
 * <Button label="Search" icon="search" variant="outline" />
 */
const Button = React.memo(function Button({
  label,
  onPress,
  variant = 'primary',
  size = 'md',
  disabled = false,
  loading = false,
  icon,
  iconPosition = 'left',
  fullWidth = false,
  testID,
  accessibilityLabel,
  accessibilityHint,
  style,
  textStyle,
  haptic = true,
}: ButtonProps) {

  // Derived states
  const isDisabled = disabled || loading;

  // Memoized styles
  const containerStyles = useMemo<ViewStyle[]>(
    () => [
      styles.button,
      styles[`button_${variant}`],
      styles[`button_${size}`],
      isDisabled && styles.buttonDisabled,
      fullWidth && styles.buttonFullWidth,
      style,
    ].filter(Boolean) as ViewStyle[],
    [variant, size, isDisabled, fullWidth, style]
  );

  const labelStyles = useMemo<TextStyle[]>(
    () => [
      styles.label,
      styles[`label_${variant}`],
      styles[`label_${size}`],
      isDisabled && styles.labelDisabled,
      textStyle,
    ].filter(Boolean) as TextStyle[],
    [variant, size, isDisabled, textStyle]
  );

  // Icon size based on button size
  const iconSize = useMemo(() => {
    const sizesMap = { sm: 14, md: 16, lg: 18 };
    return sizesMap[size];
  }, [size]);

  // Icon color
  const iconColor = useMemo(() => {
    if (variant === 'outline' || variant === 'ghost') return colors.primary;
    return colors.white;
  }, [variant]);

  // Handle press with haptic feedback
  const handlePress = React.useCallback(
    async (e: GestureResponderEvent) => {
      if (isDisabled) return;

      if (haptic) {
        try {
          await Haptics.selectionAsync();
        } catch (err) {
          // Haptics might not be available on this device
        }
      }

      onPress?.(e);
    },
    [onPress, isDisabled, haptic]
  );

  return (
    <Pressable
      onPress={handlePress}
      disabled={isDisabled}
      android_ripple={{
        color: 'rgba(0, 0, 0, 0.1)',
        borderless: false,
      }}
      accessible
      accessibilityRole="button"
      accessibilityLabel={accessibilityLabel || label}
      accessibilityHint={accessibilityHint}
      accessibilityState={{ disabled: isDisabled, busy: loading }}
      testID={testID}
      style={({ pressed }) => [
        ...containerStyles,
        pressed && !isDisabled && styles.buttonPressed,
      ]}
    >
      {/* Icon left */}
      {icon && iconPosition === 'left' && !loading && (
        <MaterialIcons
          name={icon}
          size={iconSize}
          color={iconColor}
          style={styles.iconLeft}
        />
      )}

      {/* Loading spinner */}
      {loading && (
        <ActivityIndicator
          color={variant === 'outline' || variant === 'ghost' ? colors.primary : colors.white}
          size={iconSize}
          style={styles.spinner}
        />
      )}

      {/* Label */}
      <Text style={labelStyles} numberOfLines={1} allowFontScaling={false}>
        {label}
      </Text>

      {/* Icon right */}
      {icon && iconPosition === 'right' && !loading && (
        <MaterialIcons
          name={icon}
          size={iconSize}
          color={iconColor}
          style={styles.iconRight}
        />
      )}
    </Pressable>
  );
});

Button.displayName = 'Button';

/**
 * Stylesheet - All variants, sizes, and states
 */
const styles = StyleSheet.create({
  // Base button
  button: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'center',
    borderRadius: radii.lg,
    gap: spacing[1],
    paddingHorizontal: spacing[4],
    paddingVertical: spacing[2],
    minHeight: 44,
    ...shadows.sm,
  },

  // ===== VARIANTS =====

  // Primary - Brand color, solid background
  button_primary: {
    backgroundColor: colors.primary,
    borderWidth: 0,
  },

  // Secondary - Orange, rewards
  button_secondary: {
    backgroundColor: colors.secondary,
    borderWidth: 0,
  },

  // Outline - Bordered, transparent background
  button_outline: {
    backgroundColor: colors.white,
    borderWidth: 2,
    borderColor: colors.primary,
  },

  // Ghost - Transparent, no border
  button_ghost: {
    backgroundColor: 'transparent',
    borderWidth: 0,
  },

  // ===== SIZES =====

  button_sm: {
    paddingVertical: spacing[1],
    paddingHorizontal: spacing[2],
    minHeight: 36,
  },

  button_md: {
    paddingVertical: spacing[2],
    paddingHorizontal: spacing[4],
    minHeight: 44,
  },

  button_lg: {
    paddingVertical: spacing[3],
    paddingHorizontal: spacing[5],
    minHeight: 52,
  },

  // ===== STATES =====

  buttonDisabled: {
    opacity: 0.5,
  },

  labelDisabled: {
    opacity: 0.7,
  },

  buttonPressed: {
    opacity: 0.8,
    transform: [{ scale: 0.98 }],
  },

  buttonFullWidth: {
    width: '100%',
  },

  // ===== TEXT LABELS =====

  label: {
    ...typography.labelMedium,
    textAlign: 'center',
    flex: 0,
  },

  label_primary: {
    color: colors.white,
  },

  label_secondary: {
    color: colors.white,
  },

  label_outline: {
    color: colors.primary,
  },

  label_ghost: {
    color: colors.primary,
  },

  // Size-specific labels
  label_sm: {
    ...typography.labelSmall,
    fontSize: 12,
  },

  label_md: {
    ...typography.labelMedium,
    fontSize: 14,
  },

  label_lg: {
    ...typography.labelLarge,
    fontSize: 16,
  },

  // ===== ICONS =====

  iconLeft: {
    marginRight: spacing[1],
  },

  iconRight: {
    marginLeft: spacing[1],
  },

  spinner: {
    marginRight: spacing[1],
  },
});

export default Button;
export type { ButtonProps, ButtonVariant, ButtonSize, ButtonState };
</file>

