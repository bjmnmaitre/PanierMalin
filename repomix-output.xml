// screens/SearchMapScreen.tsx
//
// Écran central "Je cherche..." (onglet 3/5) — fusionne recherche et carte
// Waze-like : radar de magasins, filtres par enseigne, itinéraire, promos en direct.

import * as React from 'react';
import { useState, useEffect, useRef, useMemo } from 'react';
import {
  View,
  Text,
  StyleSheet,
  TouchableOpacity,
  Dimensions,
