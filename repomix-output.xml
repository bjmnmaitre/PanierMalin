};

/**
 * Semantic colors for UI states
 */
export const SEMANTIC = {
  // Success - Positive actions, confirmations
  success: '#10B981',
  success_light: '#D1FAE5',
  success_dark: '#059669',
  
  // Error - Warnings, deletions, critical states
  error: '#EF4444',
