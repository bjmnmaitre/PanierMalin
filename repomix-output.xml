// components/primitives/index.ts
// Central export point for all primitive components

export { default as Button } from './Button';
export type { ButtonProps, ButtonVariant, ButtonSize, ButtonState } from './Button';

export { default as Card } from './Card';
export type { CardProps, CardShadow, CardPadding } from './Card';

