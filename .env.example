# .env.example — Variables d'environnement PanierMalin
# ══════════════════════════════════════════════════════════════
# DÉVELOPPEMENT LOCAL
# ══════════════════════════════════════════════════════════════
# Copie ce fichier en ".env" à la racine et remplis les valeurs.
# (Dashboard Supabase → Project Settings → API)
#
# Ces variables sont PUBLIQUES (préfixe EXPO_PUBLIC_ = bundlées
# dans le build). Utilise uniquement l'Anon Key, jamais la
# Service Role Key dans le code client.

EXPO_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXX

# ══════════════════════════════════════════════════════════════
# PRODUCTION — EAS SECRETS (ne PAS mettre dans ce fichier)
# ══════════════════════════════════════════════════════════════
# Pour injecter des credentials de production distincts dans les
# builds EAS sans les committer dans git, utilise les EAS Secrets :
#
#   eas secret:create --scope project \
#     --name EXPO_PUBLIC_SUPABASE_URL \
#     --value "https://PROD-PROJET.supabase.co"
#
#   eas secret:create --scope project \
#     --name EXPO_PUBLIC_SUPABASE_ANON_KEY \
#     --value "sb_publishable_PROD_KEY"
#
# EAS injecte automatiquement ces secrets lors du build EAS.
# Les secrets ont priorité sur les variables locales (.env).
# Voir : https://docs.expo.dev/eas/environment-variables/

# ══════════════════════════════════════════════════════════════
# FUTURS SERVICES (non actifs en V1)
# ══════════════════════════════════════════════════════════════
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
